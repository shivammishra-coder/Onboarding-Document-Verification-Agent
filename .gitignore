# =====================================================================
# CREDENTIALS / SECRETS - never commit these
# =====================================================================
.env
.env.*
!.env.example
*credentials*.json
*secrets*.json

# =====================================================================
# PYTHON
# =====================================================================
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
build/
dist/
*.egg-info/
.eggs/

# Virtual environments
.venv/
venv/
env/
ENV/

# Type/test caches
.mypy_cache/
.pytest_cache/
.ruff_cache/

# =====================================================================
# CANDIDATE DATA / UPLOADS - real or dummy documents and PII should
# never end up in a public (or even private) git history
# =====================================================================
backend/uploads/
backend/app/uploads/
backend/data/db.json
backend/app/test_documents/
backend/app/valid_test_documents/
backend/app/invalid_test_documents/
*.jpg
*.jpeg
*.png
!frontend/**/*.png
!frontend/**/*.jpg
!docs/**/*.png

# =====================================================================
# NODE / FRONTEND (React/Vite) - if you have a frontend folder
# =====================================================================
node_modules/
frontend/dist/
frontend/.vite/
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# =====================================================================
# EDITOR / OS
# =====================================================================
.vscode/
.idea/
*.swp
.DS_Store
Thumbs.db

# =====================================================================
# LOGS
# =====================================================================
*.log
logs/